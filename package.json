{
  "name": "nitra-frontend-assignment",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "quasar dev",
    "build": "quasar build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,vue,scss,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,vue,scss,json,md}\"",
    "check": "eslint . && prettier --check \"**/*.{js,vue,scss,json,md}\"",
    "fix": "eslint . --fix && prettier --write \"**/*.{js,vue,scss,json,md}\""
  },
  "dependencies": {
    "@quasar/extras": "1.17.0",
    "quasar": "2.18.5",
    "vue": "3.5.17",
    "vue-router": "4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@quasar/app-vite": "2.2.1",
    "@quasar/cli": "2.4.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "sass-embedded": "1.92.0",
    "unocss": "66.3.3",
    "vue-eslint-parser": "^10.4.1"
  },
  "engines": {
    "node": "22.17.0",
    "yarn": "4.6.0"
  },
  "packageManager": "yarn@4.6.0"
}
